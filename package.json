{
  "name": "bibtex-clean",
  "type": "module",
  "version": "1.1.0",
  "description": "清理 Zotero 条目的 BibTeX 导出",
  "config": {
    "addonName": "BibTeX Clean",
    "addonID": "bibtex-clean@ouyangjiahong.github.io",
    "addonRef": "bibtexclean",
    "addonInstance": "BibTeXClean",
    "prefsPrefix": "extensions.zotero.bibtexclean"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cislunarspace/bibtex-clean.git"
  },
  "author": "ouyangjiahong",
  "bugs": {
    "url": "https://github.com/cislunarspace/bibtex-clean/issues"
  },
  "homepage": "https://github.com/cislunarspace/bibtex-clean#readme",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "zotero-plugin-toolkit": "^5.1.4"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.0",
    "@zotero-plugin/eslint-config": "^0.6.9",
    "chai": "^6.2.2",
    "eslint": "^9.39.2",
    "mocha": "^11.7.6",
    "prettier": "^3.9.4",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.7",
    "zotero-types": "^4.1.2"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
